{
  "name": "@memestar/shared",
  "version": "0.1.0",
  "private": true,
  "description": "MemeChatAI 三端共享层：TS 类型、API client、常量、AI prompt 模板",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/types/index.js",
      "default": "./dist/types/index.js"
    },
    "./api-client": {
      "types": "./dist/api-client/index.d.ts",
      "require": "./dist/api-client/index.js",
      "default": "./dist/api-client/index.js"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "require": "./dist/constants/index.js",
      "default": "./dist/constants/index.js"
    },
    "./prompts": {
      "types": "./dist/prompts/index.d.ts",
      "require": "./dist/prompts/index.js",
      "default": "./dist/prompts/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "typescript": "^5.6.2"
  }
}
