{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/Users/xiaozisong/Desktop/MemeChatAI"],
      "enabled": true,
      "env": {}
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_TOKEN}"
      }
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "env": {}
    },
    "postgres": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-postgres", "{env:POSTGRES_MCP_URL}"],
      "enabled": true,
      "env": {}
    },
    "figma": {
      "type": "local",
      "command": ["npx", "-y", "figma-developer-mcp@latest"],
      "enabled": true,
      "env": {
        "FIGMA_API_KEY": "{env:FIGMA_ACCESS_TOKEN}"
      }
    }
  }
}
