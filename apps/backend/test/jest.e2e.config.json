{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "rootDir": ".",
  "roots": ["<rootDir>/e2e"],
  "testMatch": ["**/*.spec.ts"],
  "moduleFileExtensions": ["ts", "js", "json"],
  "transform": {
    "^.+\\.ts$": ["ts-jest", { "tsconfig": { "target": "ES2021", "module": "commonjs", "esModuleInterop": true } }]
  },
  "testTimeout": 30000,
  "verbose": true,
  "collectCoverage": false
}
