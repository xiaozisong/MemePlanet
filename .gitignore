# =============================================================================
# MemeChatAI .gitignore
# 覆盖 Node / pnpm / TypeScript / Expo / React Native / Next.js / Env / IDE / OS / Docker
# =============================================================================

# ---- Dependencies ----
node_modules/
.pnp
.pnp.js
.yarn/
.pnpm-store/

# ---- Build outputs ----
dist/
build/
out/
*.tsbuildinfo
next-build/
.turbo/
.cache/

# ---- Next.js ----
.next/
.vercel/

# ---- Expo / React Native ----
.expo/
.expo-shared/
expo-env.d.ts
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/
apps/mobile/ios/
apps/mobile/android/
apps/mobile/.dart_tool/

# ---- TypeScript ----
*.d.ts.map

# ---- Testing ----
coverage/
*.lcov
.nyc_output/

# ---- Env ----
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
!.env.example
!.env.*.example

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- IDE / Editor ----
.idea/
.vscode/*
!.vscode/settings.example.json
!.vscode/extensions.json
!.vscode/launch.json
*.swp
*.swo
*~
.history/

# ---- OS ----
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ---- Docker ----
docker-compose.override.yml
postgres-data/
redis-data/
pg_data/
redis_data/

# ---- Sentry / PostHog ----
.sentryclirc
sentry.properties

# ---- Misc ----
*.pid
*.seed
*.pid.lock
.tmp/
tmp/
.tmpdir/
