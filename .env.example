# =============================================================================
# MemeChatAI 环境变量模板（根目录）
# 对齐 TechnicalDesign.md 附录 A
# 复制为 .env 并填入真实值；切勿提交真实 .env
# =============================================================================

# ---- 应用 ----
NODE_ENV=development
PORT=3000
APP_NAME=memechatai
APP_ENV=development

# ---- 数据库（PostgreSQL 16 + pgvector）----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=meme
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_in_prod
DATABASE_URL=postgresql://app:change_me_in_prod@postgres:5432/meme
PGVECTOR_ENABLED=true

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

# ---- JWT ----
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ---- Supabase（Auth + Realtime）----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# ---- LLM Providers ----
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
GLM_API_KEY=your_glm_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
QWEN_API_KEY=your_qwen_key

# ---- Image Providers ----
SILICONFLOW_API_KEY=your_siliconflow_key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
TONGYI_API_KEY=your_tongyi_key

# ---- Video Providers（火山方舟 豆包 Seedance）----
VOLCANO_APP_ID=your_volcano_app_id
VOLCANO_API_KEY=your_volcano_api_key
VOLCANO_TTS_APPID=your_tts_appid
VOLCANO_TTS_TOKEN=your_tts_token
VOLCANO_TTS_CLUSTER=volcano_tts
JIMENG_API_KEY=your_jimeng_key

# ---- Storage（Cloudflare R2，S3 兼容）----
R2_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=memestar
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://cdn.memestar.xyz
R2_REGION=auto

# ---- 内容安全（阿里云）----
ALIYUN_AUDIT_ACCESS_KEY=your_aliyun_access_key
ALIYUN_AUDIT_SECRET_KEY=your_aliyun_secret_key
ALIYUN_AUDIT_REGION=cn-shanghai

# ---- 监控 ----
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com
UPTIMEROBOT_API_KEY=

# ---- 推送（OneSignal）----
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=

# ---- 短信（阿里云/腾讯云）----
SMS_PROVIDER=aliyun
ALIYUN_SMS_ACCESS_KEY=your_aliyun_sms_access_key
ALIYUN_SMS_SECRET_KEY=your_aliyun_sms_secret_key
ALIYUN_SMS_SIGN_NAME=梗星球
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxxx

# ---- 微信支付 ----
WECHAT_PAY_MCH_ID=your_mch_id
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_APP_ID=your_wechat_app_id
WECHAT_PAY_CERT_SERIAL_NO=your_cert_serial_no
WECHAT_PAY_PRIVATE_KEY_PATH=./certs/wechat_pay_private_key.pem
WECHAT_PAY_NOTIFY_URL=https://api.memestar.xyz/webhooks/wechat-pay

# ---- 客户端 ----
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_ONESIGNAL_APP_ID=
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=

# ---- AI 成本控制 ----
AI_DAILY_BUDGET_CENTS=10000
AI_DAILY_BUDGET_HARD_LIMIT_CENTS=20000
AI_AGENT_DAILY_BUDGET_CENTS=8000
AI_VIDEO_DAILY_BUDGET_CENTS=20000

# ---- CORS ----
CORS_ORIGINS=http://localhost:3000,http://localhost:8081,http://localhost:3001
